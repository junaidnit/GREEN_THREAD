{
  "manifest_version": 3,
  "name": "The Fibre Set — Fabric Check",
  "version": "0.2.0",
  "description": "See what any garment is really made of while you shop, and find real natural-fibre alternatives from The Fibre Set.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Check this garment's fibre",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"]
}
